<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:InventoryManagementSystem.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="InventoryManagementSystem.UI.Views.UsersView"
             x:DataType="vm:UsersViewModel">
    
    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="Overlay"
               OpenPaneLength="420"
               PaneBackground="White">
        <SplitView.Pane>
            <ScrollViewer Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding PaneTitle}" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                    
                    <TextBox Watermark="Username" Text="{Binding Username}" IsReadOnly="{Binding IsUsernameReadOnly}"/>
                    <TextBox Watermark="Password" Text="{Binding Password}" PasswordChar="*"/>
                    <TextBlock Text="Leave password blank when editing to keep the current password." FontSize="11" Foreground="#888"
                               IsVisible="{Binding IsUsernameReadOnly}"/>
                    
                    <TextBlock Text="Role (template)" Foreground="#666" FontSize="12"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" HorizontalAlignment="Stretch"/>
                    <Button Content="Apply role defaults to modules" Command="{Binding ApplyRoleTemplateCommand}" HorizontalAlignment="Left" Background="Transparent"/>

                    <TextBlock Text="Module access (customize per user)" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock Text="Check only the apps this user should see. This overrides the role template." FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding ModuleAccess}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:UserModuleAccessItem">
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsGranted}" Margin="0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5252" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#2E7D32" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Close" Command="{Binding ClosePaneCommand}" />
                        <Button Content="Save" Classes="accent" Command="{Binding SaveUserCommand}" Background="#007ACC" Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </SplitView.Pane>
        
        <SplitView.Content>
            <Grid RowDefinitions="Auto, Auto, *" Margin="30">
                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                    <TextBlock Text="User Management" FontSize="28" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="+ New User" Command="{Binding OpenAddUserPaneCommand}" Background="#2E7D32" Foreground="White"/>
                </Grid>

                <TextBlock Grid.Row="1" Text="{Binding SuccessMessage}" Foreground="#2E7D32" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Users}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          GridLinesVisibility="All"
                          BorderThickness="1" BorderBrush="#EEE" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLoginAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                        <DataGridTemplateColumn Header="Actions" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Edit" Command="{Binding $parent[UserControl].((vm:UsersViewModel)DataContext).OpenEditUserPaneCommand}" CommandParameter="{Binding .}" Background="#007ACC" Foreground="White" FontSize="10" Padding="6,2"/>
                                        <Button Content="Delete" Command="{Binding $parent[UserControl].((vm:UsersViewModel)DataContext).DeleteUserCommand}" CommandParameter="{Binding .}" Background="#D32F2F" Foreground="White" FontSize="10" Padding="6,2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </SplitView.Content>
    </SplitView>
</UserControl>
